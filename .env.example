# Soraia Oliveira Portfolio — Environment Variables
# Copy this file to .env.local for local development
# For Vercel: paste these into Settings → Environment Variables
#
# All variables are OPTIONAL for build — the site renders with mock data.
# Add them one by one as you set up each service (see DEPLOYMENT.md).

# ─── Database (Neon) ───────────────────────────────────────────────
# Get from: https://console.neon.tech → Project → Connection Details → Pooled
DATABASE_URL=

# ─── Admin Authentication ──────────────────────────────────────────
# AUTH_SECRET: run `openssl rand -base64 32`
# ADMIN_PASSWORD_HASH: run `node -e "require('bcryptjs').hash('YOUR_PASSWORD', 12).then(h => console.log(h))"`
AUTH_SECRET=
ADMIN_EMAIL=soraia@soraia-oliveira.com
ADMIN_PASSWORD_HASH=

# ─── Stripe (Payments) ────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Webhook secret from: https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Resend (Email) ───────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=
CONTACT_NOTIFICATION_EMAIL=info@soraia-oliveira.com

# ─── Uploadthing (Image Storage) ──────────────────────────────────
# Get from: https://uploadthing.com/dashboard → App → API Keys
UPLOADTHING_TOKEN=

# ─── Application ──────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://soraia-oliveira.com
REVALIDATION_SECRET=
