# ─── Database (Neon) ───
# Optional for development — site renders with mock data when not set
DATABASE_URL=

# ─── Authentication ───
# Required for /admin access. Generate AUTH_SECRET with: openssl rand -base64 32
# Generate ADMIN_PASSWORD_HASH with: node -e "require('bcryptjs').hash('your-password', 12).then(h => console.log(h))"
AUTH_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# ─── Payments (Stripe) ───
# Optional — purchase buttons will error without these, but site renders fine
# Use sk_test_ / pk_test_ keys for development, sk_live_ / pk_live_ for production
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Email (Resend) ───
# Optional — contact form submissions save to DB but won't send email notifications
RESEND_API_KEY=
CONTACT_NOTIFICATION_EMAIL=

# ─── Image Upload (Uploadthing) ───
# Optional — required only for admin image uploads
UPLOADTHING_TOKEN=

# ─── Application ───
NEXT_PUBLIC_BASE_URL=http://localhost:3000
REVALIDATION_SECRET=
